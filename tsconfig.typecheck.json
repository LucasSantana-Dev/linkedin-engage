{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021", "DOM"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "*.js",
    "extension/**/*.js",
    "tests/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "linkedin_session"
  ]
}
